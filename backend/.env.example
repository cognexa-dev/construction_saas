# Server
NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# Database — Railway injects DATABASE_URL automatically when you add a Postgres service.
# If using Railway Postgres, set only DATABASE_URL (leave DB_* vars blank).
DATABASE_URL=

# Fallback individual DB vars (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forever_buildcon
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# JWT — use long random strings in production
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
AES_SECRET_KEY=your_32_char_aes_key_here_exactly_

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS — set to your Railway frontend URL in production
# e.g. https://construction-saas-frontend.up.railway.app
CORS_ORIGIN=http://localhost:5173

# OpenRouter AI (for budget estimation)
# Get your free key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
